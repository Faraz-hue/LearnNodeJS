<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            min-height: 100vh;
        }

        .navbar {
            background: white;
            padding: 18px 40px;
            box-shadow: 0 2px 10px rgba(0, 0, 0, .1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar h2 {
            color: #4f46e5;
        }

        .navbar a {
            text-decoration: none;
            color: #4f46e5;
            font-weight: 600;
            margin-left: 20px;
        }

        .container {
            width: 90%;
            max-width: 1000px;
            margin: 40px auto;
            background: white;
            border-radius: 15px;
            padding: 35px;
            box-shadow: 0 15px 40px rgba(0, 0, 0, .15);
        }

        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 25px;
        }

        form {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-bottom: 30px;
        }

        label {
            width: 100%;
            font-weight: 600;
            color: #555;
        }

        input[type="text"] {
            flex: 1;
            padding: 14px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            transition: .3s;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: #4f46e5;
            box-shadow: 0 0 6px rgba(79, 70, 229, .3);
        }

        button {
            background: #4f46e5;
            color: white;
            border: none;
            padding: 14px 24px;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            transition: .3s;
        }

        button:hover {
            background: #4338ca;
        }

        .result {
            background: #ecfdf5;
            border-left: 5px solid #22c55e;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 25px;
        }

        .result p {
            font-weight: 600;
        }

        .result a {
            color: #2563eb;
            text-decoration: none;
            word-break: break-word;
        }

        .result a:hover {
            text-decoration: underline;
        }

        h3 {
            margin-bottom: 15px;
            color: #333;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            overflow: hidden;
            border-radius: 10px;
        }

        thead {
            background: #4f46e5;
            color: white;
        }

        th,
        td {
            padding: 14px;
            border-bottom: 1px solid #eee;
            text-align: left;
        }

        tbody tr:nth-child(even) {
            background: #f9fafb;
        }

        tbody tr:hover {
            background: #eef2ff;
        }

        @media(max-width:768px) {

            form {
                flex-direction: column;
            }

            button {
                width: 100%;
            }

            table {
                display: block;
                overflow-x: auto;
            }

            .navbar {
                flex-direction: column;
                gap: 10px;
            }
        }
    </style>
</head>

<body>

    <nav class="navbar">
        <h2>🔗 URL Shortener</h2>

        <div>
            <a href="/">Home</a>
            <a href="/login">Login</a>
            <a href="/signup">Sign Up</a>
        </div>
    </nav>

    <div class="container">

        <h1>Shorten Your Long URLs</h1>

        <% if (locals.id) { %>
            <div class="result">
                <p>Your Short URL is:</p>
                <br>
                <a href="http://localhost:8001/url/<%= id %>" target="_blank">
                    http://localhost:8001/url/<%= id %>
                </a>
            </div>
            <% } %>

                <form method="POST" action="/url">

                    <label>Enter Your Original URL</label>

                    <input type="text" name="url" placeholder="https://example.com" required>

                    <button type="submit">Generate URL</button>

                </form>

                <% if(locals.urls){ %>

                    <h3>Your URLs</h3>

                    <table>

                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Short ID</th>
                                <th>Original URL</th>
                                <th>Clicks</th>
                            </tr>
                        </thead>

                        <tbody>

                            <% urls.forEach((url,index)=>{ %>

                                <tr>

                                    <td>
                                        <%= index + 1 %>
                                    </td>

                                    <td>
                                        <a href="/url/<%= url.shortId %>">
                                            <%= url.shortId %>
                                        </a>
                                    </td>

                                    <td style="word-break: break-all;">
                                        <%= url.redirectURL %>
                                    </td>

                                    <td>
                                        <%= url.visitHistory.length %>
                                    </td>

                                </tr>

                                <% }) %>

                        </tbody>

                    </table>

                    <% } %>

    </div>

</body>

</html>